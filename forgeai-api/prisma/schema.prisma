// ForgeAI Prisma Schema
// --------------------------
// Phase 0: User, Workspace, Repository models
// Phase 1: CodeChunk (with pgvector embeddings)
// Phase 2: SkillRun (bug fix tracking)
// Phase 3: Code Review and Documentation skills
// Phase 4: Code Execution Sandbox
// Phase 5: Swappable embedding providers (Gemini/Jina)
// Phase 6: GitBrain Lite — DiscoveredRepo catalog (separate from user repos)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum IndexingStatus {
  PENDING
  INDEXING
  COMPLETED
  FAILED
}

enum SkillType {
  BUGFIX
  REVIEW
  DOCS
}

enum SkillRunStatus {
  PROPOSED
  APPROVED
  REJECTED
}

// Tracks async machine execution state — separate from human approval (SkillRunStatus)
enum ExecutionStatus {
  NOT_STARTED
  QUEUED
  RUNNING
  DONE
}

model User {
  id          String      @id @default(cuid())
  githubId    Int         @unique
  username    String      @unique
  displayName String?
  avatarUrl   String?
  email       String?
  githubToken String      // AES-256-GCM encrypted
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  workspaces  Workspace[]

  @@map("users")
}

model Workspace {
  id           String       @id @default(cuid())
  name         String
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  repositories Repository[]
  skillRuns    SkillRun[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("workspaces")
}

model Repository {
  id             String         @id @default(cuid())
  name           String
  owner          String
  githubUrl      String
  defaultBranch  String         @default("main")
  workspaceId    String
  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  indexingStatus IndexingStatus @default(PENDING)
  indexingError  String?
  embeddingProvider String    @default("GEMINI")
  lastIndexedAt  DateTime?
  chunks         CodeChunk[]
  skillRuns      SkillRun[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([workspaceId, githubUrl])
  @@map("repositories")
}

model CodeChunk {
  id           String     @id @default(cuid())
  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  filePath     String
  content      String
  startLine    Int
  endLine      Int
  embedding    Unsupported("vector(1536)")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("code_chunks")
}

model SkillRun {
  id              String          @id @default(cuid())
  workspaceId     String
  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  repositoryId    String
  repository      Repository      @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  skillType       SkillType       @default(BUGFIX)
  input           String          // The error message / stack trace
  proposedDiff    Json?           // { filePath, startLine, endLine, originalCode, proposedCode, explanation }
  status          SkillRunStatus  @default(PROPOSED)
  prUrl           String?
  // Phase 4: Execution sandbox fields
  executionStatus ExecutionStatus @default(NOT_STARTED)
  attemptCount    Int             @default(0)   // incremented in DB before each execution attempt
  executionResult Json?           // { stdout, stderr, exitCode, passed, language, attemptedAt, capReached? }
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("skill_runs")
}

// Phase 6: GitBrain Lite — curated discovery catalog.
// Entirely separate from user Repository/Workspace tables — no foreign keys.
// Populated exclusively by the weekly scheduled discovery BullMQ job.
// Tags are LLM-generated best-effort (not a trained classifier).
//
// Health score formula (see discovery.worker.ts for full derivation):
//   clamp(log10(stars+1)*10 + max(0,40-daysSincePush/4) + max(0,20-issueRatio*100), 0, 100) / 100
//
// Embedding dimension: 1536 (matches code_chunks; Jina 1024-dim vectors are zero-padded).
// embeddingProvider: tracks which provider was used for this row's embedding,
//   so the search endpoint can filter to a consistent vector space.
model DiscoveredRepo {
  id                String   @id @default(cuid())
  githubUrl         String   @unique
  owner             String
  name              String
  description       String?
  stars             Int      @default(0)
  openIssues        Int      @default(0)
  lastPushedAt      DateTime
  domainTags        String[]
  techTags          String[]
  architectureTags  String[]
  healthScore       Float    @default(0)
  embedding         Unsupported("vector(1536)")?
  embeddingProvider String   @default("GEMINI")
  readmeSummary     String?  // stored for re-embedding without re-fetching
  lastRefreshedAt   DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("discovered_repos")
}


