# =============================================================================
# ForgeAI API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# =============================================================================

# Server
PORT=4000
NODE_ENV=development

# Database — PostgreSQL with pgvector extension
# Get from: Neon (https://neon.tech) or Supabase (https://supabase.com)
DATABASE_URL=postgresql://user:password@host:5432/forgeai?sslmode=require

# Redis — for BullMQ job queues
# Get from: Upstash (https://upstash.com)
REDIS_URL=rediss://default:password@host:6379

# GitHub OAuth App
# Create at: https://github.com/settings/developers → "New OAuth App"
# Homepage URL: http://localhost:3000
# Callback URL: http://localhost:3000/api/auth/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# JWT Session Secret — at least 32 characters
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_jwt_secret_at_least_32_chars

# Encryption Key — exactly 64 hex chars (32 bytes) for AES-256-GCM
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_encryption_key_for_aes256gcm

# Frontend URL — for CORS and OAuth redirects
FRONTEND_URL=http://localhost:3000

# Indexing Guardrails (optional overrides)
# MAX_INDEX_FILES=2000
# MAX_FILE_SIZE_KB=512

# AI Services
# At least one LLM key (GEMINI_API_KEY or OPENAI_API_KEY or GROQ_API_KEY) is required.
# At least one embedding key (GEMINI_API_KEY or OPENAI_API_KEY or VOYAGE_API_KEY) is required.
#
# Google Gemini (LLM + embeddings): https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
#
# OpenAI (LLM + embeddings): https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key
#
# Groq (LLM only, fast inference): https://console.groq.com/keys
# GROQ_API_KEY=your_groq_api_key
#
# Voyage AI (embeddings only): https://docs.voyageai.com/docs/api-key-and-installation
# VOYAGE_API_KEY=your_voyage_api_key

# Code Execution Sandbox (Phase 4 — both optional)
# Judge0 self-hosted instance (opportunistic; Piston is the public fallback)
# JUDGE0_BASE_URL=https://your-judge0-instance.example.com
# JUDGE0_API_KEY=your_judge0_api_key
